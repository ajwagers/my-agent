# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

TELEGRAM_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
AGENT_URL=http://agent-core:8000

# Redis authentication
REDIS_PASSWORD=your_redis_password_here

# API key for agent REST endpoints
AGENT_API_KEY=your_api_key_here

# Web search
TAVILY_API_KEY=your_tavily_key_here
BRAVE_SEARCH_API_KEY=your_brave_key_here

# Mumble voice gateway
MUMBLE_SUPERUSER_PASSWORD=changeme
MUMBLE_SERVER_PASSWORD=

# Outlook / MS Graph
MS_GRAPH_CLIENT_ID=your_azure_app_client_id_here

# Open Brain MCP (PostgreSQL + pgvector)
BRAIN_POSTGRES_PASSWORD=your_secure_db_password_here

# Mumble owner identity
# Step 1: set MUMBLE_OWNER_USERNAMES to your Mumble display name (fallback auth)
# Step 2: connect once, then run: docker compose logs mumble-bot | grep "Cert hash"
# Step 3: copy the hash into MUMBLE_OWNER_CERT_HASH (stronger certificate-based auth)
MUMBLE_OWNER_USERNAMES=Andy
MUMBLE_OWNER_CERT_HASH=            # leave blank until you have the hash
